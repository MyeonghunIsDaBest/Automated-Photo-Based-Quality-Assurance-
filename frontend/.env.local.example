# Copy this file to `.env.local` and fill in the values from your
# Supabase project (Dashboard → Project Settings → API).
#
# .env.local is git-ignored. Do NOT commit real keys.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── AI (optional) ─────────────────────────────────────────────────────────
# Enables real Anthropic calls for the Polish button + future text-AI
# surfaces. When false (or unset), the app falls back to the deterministic
# mock writer in lib/api/mockWritingAssist.ts so the demo still works
# without any API key in place.
#
# IMPORTANT: the Anthropic API key itself does NOT live here — it lives as
# a Supabase Edge Function secret called ANTHROPIC_API_KEY. Setting this
# flag to "true" only tells the frontend to call the `polish-text` Edge
# Function instead of the local mock. The Edge Function does the real work.
#
# Set the secrets via:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-…
#   supabase secrets set ANTHROPIC_DAILY_CALL_CAP=50
#   supabase secrets set ANTHROPIC_DAILY_TOKEN_CAP=200000
#   supabase secrets set ANTHROPIC_MAX_TOKENS=1024
#   supabase secrets set ANTHROPIC_DISABLED=false
#
# Defaults if unset on the Edge side:
#   ANTHROPIC_DAILY_CALL_CAP   = 50 calls/day (project-wide)
#   ANTHROPIC_DAILY_TOKEN_CAP  = 200000 tokens/day (≈$3 at Sonnet pricing)
#   ANTHROPIC_MAX_TOKENS       = 1024 per response
#   ANTHROPIC_DISABLED         = false  (set "true" to kill-switch all calls)
VITE_ENABLE_REAL_AI=false
