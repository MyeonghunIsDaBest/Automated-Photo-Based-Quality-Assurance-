# Supabase Edge Function secrets — set via `supabase secrets set KEY=VALUE`.
# These are NOT bundled into the frontend; they're read at request time by
# the Edge Function runtime via Deno.env.get().
#
# Apply with:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-…
#   supabase secrets list   # to confirm
#
# Anthropic credentials — the only required entry for AI features.
ANTHROPIC_API_KEY=sk-ant-replace-me

# Default model. Haiku is ~3× cheaper than Sonnet ($1/$5 vs $3/$15 per 1M
# tokens) and adequate for both surfaces — construction-photo classification
# and short-form diary polish are well within Haiku 4.5's capability. Flip
# per-project to Sonnet via `project_config.ai_default_model` when a pilot
# customer needs higher fidelity (rare); the default here protects the
# starter API credit from being burned on dev iterations.
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5

# ─── Rate limits (testing-safe defaults) ─────────────────────────────────────
# Daily aggregate caps reset at UTC midnight. The Edge Function reads
# `ai_usage_daily` (migration 13) and rejects the call once any cap is hit.
ANTHROPIC_DAILY_CALL_CAP=50
ANTHROPIC_DAILY_TOKEN_CAP=200000

# Per-response token cap. Hard ceiling regardless of caller's request.
# Polish prose rarely needs more than 512; 1024 leaves headroom for longer
# diary entries without giving the model permission to ramble.
ANTHROPIC_MAX_TOKENS=1024

# Vision-specific cap. Vision returns a small JSON object (~150–250 output
# tokens); 512 is still 2× the typical response. Lower than the polish cap
# to make accidentally-verbose vision responses impossible.
ANTHROPIC_VISION_MAX_TOKENS=512

# Kill switch. Set to "true" to short-circuit every call without any DB
# read. Use during incidents or when a runaway script is suspected.
ANTHROPIC_DISABLED=false
